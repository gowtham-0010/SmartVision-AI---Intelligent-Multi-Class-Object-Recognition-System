raw_data/
coco_annotations/
*.zip
/classification
/detection
# ---------------------------------------------------------------------------
# Logs / temp files
# ---------------------------------------------------------------------------
*.log
*.tmp
.cache/

# ---------------------------------------------------------------------------
# NOTE: models/ and outputs/ are intentionally NOT ignored here - the trained
# .keras / .pt weights and metrics JSON files are meant to be committed (via
# Git LFS for the large weight files, per the deployment README) so the
# Streamlit app has what it needs both locally and on Hugging Face Spaces.
# ---------------------------------------------------------------------------
